#!/usr/bin/env bash
GUVNAH_ROOT="/Users/asgupta/code/context-injector"
export PYTHONPATH="$GUVNAH_ROOT${PYTHONPATH:+:$PYTHONPATH}"
export GUVNAH_MACHINES="$(cd "$(dirname "$0")" && pwd)/machines"
# guvnah-ctl — CLI for guvnah workflow enforcer.
# Usage:
#   guvnah-ctl tdd         — activate TDD state machine
#   guvnah-ctl off         — deactivate
#   guvnah-ctl status      — show current state
#   guvnah-ctl transition <target> [evidence_key]
#   guvnah-ctl evidence    — show evidence locker
set -euo pipefail

# Session ID = MD5 of project directory (same as hooks)
SESSION="$(printf '%s' "$PWD" | (md5 2>/dev/null || md5sum | cut -d' ' -f1))"

ARGS="${*:-}"
if [ -z "$ARGS" ]; then
  echo "Usage: guvnah-ctl <tdd|off|status|transition|evidence>" >&2
  exit 1
fi

printf '{"prompt": "/governor %s"}' "$ARGS" \
  | python3 -m governor_v4 prompt --session "$SESSION"

{
  "enableAllProjectMcpServers": true,
  "mcpServers": {
    "neo4j": {
      "command": "uvx",
      "args": [
        "mcp-neo4j-cypher",
        "--transport",
        "stdio"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"ast-grep check: structural pattern (constructor/call sites/argument shapes/multi-line)? -> use ast-grep skill instead. Keyword/import/constant only? -> Grep OK.\"}}'",
            "statusMessage": "ast-grep check..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/context-injector/hooks/governor-hook.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/context-injector/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/context-injector/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/context-injector/hooks/post-tool-use.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/context-injector/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(basename:*)",
      "Bash(bash:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go build:*)",
      "Bash(go mod:*)",
      "Bash(go test:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make build)",
      "Bash(make lint)",
      "Bash(make test)",
      "Bash(mkdir:/tmp/ctx-governor)",
      "Bash(mkdir:/tmp/ctx-locks)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pre-commit:*)",
      "Bash(printenv:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(realpath:*)",
      "Bash(rm:/tmp/ctx-governor/)",
      "Bash(rm:/tmp/ctx-locks/)",
      "Bash(rtk proxy:*)",
      "Bash(sed:*)",
      "Bash(shellcheck:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(touch:/tmp/ctx-governor/*)",
      "Bash(touch:/tmp/ctx-locks/*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(wget:*)",
      "Bash(which:*)",
      "Bash(yq:*)",
      "LSP",
      "Read(~/.claude/**)",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  }
}

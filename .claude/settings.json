{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/inject-for-code-review.sh",
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); skill=$(echo \"$input\" | jq -r '.tool_input.skill // \"\"'); if [[ \"$skill\" == \"superpowers:writing-plans\" ]]; then content=$(printf 'When writing out the implementation plan, include the following guidelines:\\n\\n'; cat .claude/conditional/testing-patterns.md); echo \"{}\" | jq --arg ctx \"$content\" '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": $ctx}}'; fi",
            "statusMessage": "Injecting TDD guidelines for plan..."
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"ast-grep check: structural pattern (constructor/call sites/argument shapes/multi-line)? -> use ast-grep skill instead. Keyword/import/constant only? -> Grep OK.\"}}'",
            "statusMessage": "ast-grep check..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "cat .claude/core/*.md",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "~/.claude/plugins/context-injector/hooks/user-prompt-submit.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "WebFetch",
      "WebSearch",
      "LSP",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pre-commit:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(shellcheck:*)",
      "Bash(bash:*)",
      "Bash(ls:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(wc:*)",
      "Bash(date:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go test:*)",
      "Bash(go mod:*)",
      "Bash(go build:*)",
      "Bash(make build)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(rtk proxy:*)"
    ],
    "defaultMode": "acceptEdits"
  }
}

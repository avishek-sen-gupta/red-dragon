[importlinter]
root_packages =
    interpreter

[importlinter:contract:vm-no-frontend]
name = VM must not import frontend lowering code
type = forbidden
source_modules =
    interpreter.vm
    interpreter.handlers
forbidden_modules =
    interpreter.frontends
ignore_imports =
    interpreter.vm.executor -> interpreter.frontends.symbol_table

[importlinter:contract:ir-is-leaf]
name = IR module must not import other interpreter modules
type = forbidden
source_modules =
    interpreter.ir
forbidden_modules =
    interpreter.vm
    interpreter.handlers
    interpreter.cfg
    interpreter.frontends
    interpreter.run
    interpreter.llm

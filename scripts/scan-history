#!/bin/bash
# Scan full git history for forbidden terminology.
# Uses the same blocklist as the pre-commit guard.
# Output: commit SHA, file path, line number, and matching text.

BLOCKLIST="$HOME/.config/git/blocklist.txt"

if [ ! -f "$BLOCKLIST" ]; then
  echo "No blocklist found at $BLOCKLIST"
  exit 0
fi

PATTERN=$(grep -v '^\s*#' "$BLOCKLIST" | grep -v '^\s*$' | paste -sd '|' -)
if [ -z "$PATTERN" ]; then
  echo "Blocklist is empty."
  exit 0
fi

echo "Scanning git history for forbidden terms..."
echo ""

FOUND=0

# ── File contents: use git log -G for fast diff-level search ──────
# -G finds commits where the diff (added or removed lines) matches.
# Then we inspect only the matching files at those commits.
COMMITS=$(git log --all -G "$PATTERN" --pretty=format:"%H" -- 2>/dev/null | sort -u)

if [ -n "$COMMITS" ]; then
  echo -e "\033[1;31m[FAIL] Forbidden terms in file contents:\033[0m"
  echo "$COMMITS" | while read -r sha; do
    # Get the files changed in this commit that match
    FILES=$(git diff-tree --no-commit-id -r --name-only "$sha" 2>/dev/null)
    SHORT=$(git log -1 --format='%h %s' "$sha" 2>/dev/null)
    echo "$FILES" | while read -r file; do
      # Show the file at that commit, grep for matches with line numbers
      git show "$sha:$file" 2>/dev/null | grep -nE "$PATTERN" | while IFS=: read -r lineno rest; do
        echo "  $SHORT  $file:$lineno  $rest"
      done
    done
  done | head -80
  echo ""
  FOUND=1
fi

# ── Commit messages ───────────────────────────────────────────────
MSG_HITS=$(git log --all --format='%h %s%n%b' 2>/dev/null | grep -E "$PATTERN" | head -10)

if [ -n "$MSG_HITS" ]; then
  echo -e "\033[1;31m[FAIL] Forbidden terms in commit messages:\033[0m"
  echo "$MSG_HITS"
  echo ""
  FOUND=1
fi

if [ $FOUND -eq 0 ]; then
  echo -e "\033[1;32mHistory clean. No forbidden terms found.\033[0m"
fi

exit $FOUND

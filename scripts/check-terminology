#!/bin/bash
# Terminology guard — blocks commits containing forbidden project/client terms.
# Blocklist lives at ~/.config/git/blocklist.txt (one regex pattern per line).
# Excludelist lives at ~/.config/git/blocklist-exclude.txt (glob patterns to skip).
# Exit 0 = clean, Exit 1 = blocked.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib-terminology.sh"

load_pattern || exit 0
load_excludes

# ── Scan staged diff ────────────────────────────────────────────

scan_staged_changes() {
  local diff_output
  if [ -n "$EXCLUDE_ARGS" ]; then
    diff_output=$(eval "git diff --cached --diff-filter=ACMR -U0 $EXCLUDE_ARGS" 2>/dev/null)
  else
    diff_output=$(git diff --cached --diff-filter=ACMR -U0 2>/dev/null)
  fi

  # Parse unified diff to extract file names and match locations
  local current_file="" found=0 count=0

  echo "$diff_output" | while IFS= read -r line; do
    # Track current file from diff headers
    if [[ "$line" =~ ^diff\ --git\ a/(.+)\ b/ ]]; then
      current_file="${BASH_REMATCH[1]}"
      continue
    fi

    # Only look at added lines (starting with +, but not +++ header)
    if [[ "$line" =~ ^\+[^+] ]] || [[ "$line" =~ ^\+$ ]]; then
      local content="${line:1}"  # strip leading +
      if echo "$content" | grep -qE "$PATTERN"; then
        # First hit: print header
        if [ $found -eq 0 ]; then
          print_table_header "Forbidden terms in staged changes"
          found=1
        fi

        echo "$content" | grep -oE "$PATTERN" | sort -u | while read -r term; do
          local ctx
          ctx=$(snippet_around "$content" "$term")
          print_table_row "staged" "$current_file" "$term" "$ctx"
        done
        count=$((count + 1))
      fi
    fi
  done

  # Subshell issue: re-check for matches to set exit code
  if [ -n "$EXCLUDE_ARGS" ]; then
    eval "git diff --cached --diff-filter=ACMR -U0 $EXCLUDE_ARGS" 2>/dev/null | grep -qE "^\+.*($PATTERN)"
  else
    git diff --cached --diff-filter=ACMR -U0 2>/dev/null | grep -qE "^\+.*($PATTERN)"
  fi
  return $?
}

# ── Main ────────────────────────────────────────────────────────

if scan_staged_changes; then
  # Matches found — print footer and block
  local_count=$(git diff --cached --diff-filter=ACMR -U0 2>/dev/null | grep -cE "^\+.*($PATTERN)" || echo 0)
  print_table_footer "$local_count"
  print_blocked
  exit 1
fi

echo -e "${GREEN}[terminology-guard] No violations found.${RESET}"
exit 0
